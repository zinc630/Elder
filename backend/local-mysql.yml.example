spring:
  datasource:
    url: jdbc:mysql://localhost:3306/elder?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: root
    password: your_mysql_password
    driver-class-name: com.mysql.cj.jdbc.Driver
  sql:
    init:
      mode: always
      schema-locations: classpath:db/mysql/schema.sql
      continue-on-error: true

